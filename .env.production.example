# Production environment template (placeholders only — no secrets)
# Copy to Vercel Project Settings → Environment Variables

# ─── Core (Google Sheets — PRIMARY source of truth, unchanged) ───
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_PROJECT_ID=
JWT_SECRET=

NEXT_PUBLIC_APP_URL=https://wakeel-team-dashboard.vercel.app

# ─── Optional: shifts spreadsheet ───
# GOOGLE_SHEETS_SHIFTS_SPREADSHEET_ID=

# ─── Tableau performance sync ───
# CLOUDFLARE_ACCESS_CLIENT_ID=
# CLOUDFLARE_ACCESS_CLIENT_SECRET=
TABLEAU_SERVER_URL=https://tableau.deliveryhero.net
TABLEAU_SITE_CONTENT_URL=Talabat
TABLEAU_PAT_NAME=
TABLEAU_PAT_SECRET=
TABLEAU_VIEW_CONTENT_URL=RiderPerformance

# ─── Cron protection (recommended) ───
CRON_SECRET=

# Performance sync tuning
PERFORMANCE_SYNC_AUTO_APPLY_GOOD=true
PERFORMANCE_SYNC_ZERO_RATIO_THRESHOLD=0.9
PERFORMANCE_SYNC_MIN_ROWS=5

# ─── Ticketing ONLY (Neon PostgreSQL — additive layer, no Sheets migration) ───
# If unset: dashboard works; /api/ticketing/* returns 503
TICKETING_DATABASE_URL=

# Ticketing attachments (production)
TICKETING_STORAGE_PROVIDER=s3
# TICKETING_LOCAL_STORAGE_PATH=.data/ticketing-attachments
TICKETING_S3_BUCKET=
TICKETING_S3_REGION=auto
TICKETING_S3_ACCESS_KEY_ID=
TICKETING_S3_SECRET_ACCESS_KEY=
# TICKETING_S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# TICKETING_S3_PREFIX=ticketing

# ─── Optional shared cache (read-through; Sheets unchanged) ───
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ─── Optional observability (not required) ───
# SENTRY_DSN=
# SENTRY_AUTH_TOKEN=

# ─── Vercel injects automatically ───
# VERCEL=1
# VERCEL_ENV=production
