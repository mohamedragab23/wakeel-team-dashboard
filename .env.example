# Google Sheets (required for login & data)
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_PROJECT_ID=
JWT_SECRET=

# Base URL (optional — production defaults to wakeel-team-dashboard.vercel.app)
NEXT_PUBLIC_APP_URL=https://wakeel-team-dashboard.vercel.app

# Optional: shifts spreadsheet (falls back to main credentials)
# GOOGLE_SHEETS_SHIFTS_SPREADSHEET_ID=

# Cloudflare Access (required for Vercel → Tableau; get Service Token from IT)
# CLOUDFLARE_ACCESS_CLIENT_ID=
# CLOUDFLARE_ACCESS_CLIENT_SECRET=

# Tableau (Rider Performance auto-sync)
TABLEAU_SERVER_URL=https://tableau.deliveryhero.net
TABLEAU_SITE_CONTENT_URL=Talabat
TABLEAU_PAT_NAME=
TABLEAU_PAT_SECRET=
TABLEAU_VIEW_CONTENT_URL=RiderPerformance
# TABLEAU_VIEW_ID=

# Cron protection (Vercel Cron + manual trigger)
CRON_SECRET=

# Upstash Redis (optional L2 cache — read-through only; Sheets remains source of truth)
# UPSTASH_REDIS_REST_URL=   # or auto-set as KV_REST_API_URL via Vercel Upstash integration
# UPSTASH_REDIS_REST_TOKEN= # or auto-set as KV_REST_API_TOKEN via Vercel Upstash integration

# Sentry (optional — error & performance monitoring)
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_DSN=
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# Operations Ticketing (isolated PostgreSQL — not Google Sheets)
# TICKETING_DATABASE_URL=postgresql://user:pass@host:5432/ticketing?sslmode=require
# TICKETING_STORAGE_PROVIDER=local
# TICKETING_LOCAL_STORAGE_PATH=.data/ticketing-attachments
# TICKETING_STORAGE_PROVIDER=s3
# TICKETING_S3_BUCKET=
# TICKETING_S3_REGION=
# TICKETING_S3_ACCESS_KEY_ID=
# TICKETING_S3_SECRET_ACCESS_KEY=
# TICKETING_S3_ENDPOINT=
# TICKETING_S3_PREFIX=ticketing

# Talabat Live 3PL (rooster-live) — AUTO-REFRESH ARCHITECTURE
# Reuses the Upstash Redis vars above (UPSTASH_REDIS_REST_URL/_TOKEN or Vercel KV_*).
# ROOSTER_LIVE_CITY_ID=200                # falls back to ROOSTER_CITY_ID if unset
# ROOSTER_LIVE_URL_TEMPLATE=https://eg.me.logisticsbackoffice.com/api/rider-live-operations/v1/external/city/{city_id}/riders
#
# AUTH CONFIGURATION (Cookie-based, auto-refresh):
# RECOMMENDED: Use Google Sheet `cron_config` tab (no redeploy needed)
# ROOSTER_EXPORT_HEADERS_JSON={"Cookie":"CF_AppSession=...; CF_Authorization=..."}
#
# ⚠️ CRITICAL: Do NOT include Authorization: Bearer (expires every 2 hours)
# ✅ ONLY include: CF_AppSession + CF_Authorization (24h TTL, auto-refreshes dhh_token)
#
# How auto-refresh works:
# 1. CF_Authorization lasts 24 hours (update once daily in Google Sheet)
# 2. dhh_token expires every 2 hours (system auto-refreshes on 401 via Okta endpoint)
# 3. Zero manual intervention for dhh_token - only update CF_Authorization when it expires
#
# See docs/ROOSTER_LIVE.md for full setup guide.


# Auto-write when Tableau data looks healthy (default true)
PERFORMANCE_SYNC_AUTO_APPLY_GOOD=true
PERFORMANCE_SYNC_ZERO_RATIO_THRESHOLD=0.9
PERFORMANCE_SYNC_MIN_ROWS=5

# Local: copy production vars from Vercel
# npm run env:pull
