# Google Sheets API Configuration
# Copy this file to .env.local and fill in real values. NEVER commit .env.local.
GOOGLE_SHEETS_SPREADSHEET_ID=your-main-spreadsheet-id
GOOGLE_SHEETS_SHIFTS_SPREADSHEET_ID=your-shifts-spreadsheet-id

# Recommended: use two separate service accounts (both must have access to the unified sheet)
GOOGLE_SHEETS_007SUP_CREDENTIALS_PATH=./credentials/service-account-007sup.json
GOOGLE_SHEETS_SHIFTS_CREDENTIALS_PATH=./credentials/service-account-shifts.json

# Legacy fallback (optional — prefer JSON file paths above)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_WITH_YOUR_KEY_ONE_LINE_ESCAPED\n-----END PRIVATE KEY-----\n"
GOOGLE_PROJECT_ID=your-gcp-project-id

# JWT Secret for Authentication — use a long random string in production (openssl rand -base64 48)
JWT_SECRET=change-me-to-a-long-random-secret

# Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Cron (hourly) ---
# Recommended for manual triggering / extra protection:
# CRON_SECRET=change-me

# --- Rooster export automation ---
# A direct CSV export URL template. It must return CSV without interactive login when the
# proper headers are provided in ROOSTER_EXPORT_HEADERS_JSON (usually a Cookie).
#
# Placeholders:
# - {start} -> YYYY-MM-DD
# - {end}   -> YYYY-MM-DD
# - {city}  -> city label (e.g. Alexandria)
#
# Example (replace with the real export endpoint):
# ROOSTER_EXPORT_URL_TEMPLATE=https://eg.me.logisticsbackoffice.com/api/rooster/v3/shifts/export?city_id={city_id}&end_at={end_at}&page=0&size=50000&start_at={start_at}&with_evaluations=true&with_time_zone=Africa%2FCairo
#
# Optional extra headers as JSON (single line), e.g.:
# ROOSTER_EXPORT_HEADERS_JSON={"Cookie":"CF_Authorization=...; session=..."}
# If OTP expires daily, you can avoid redeploys by storing ROOSTER_EXPORT_HEADERS_JSON in Google Sheets:
# - Create a sheet/tab named `cron_config`
# - A1=key, B1=value
# - A2=ROOSTER_EXPORT_HEADERS_JSON, B2={"Cookie":"..."}
# Optional override:
# ROOSTER_SESSION_SHEET_NAME=cron_config
ROOSTER_CITY=Alexandria
ROOSTER_CITY_ID=200

# --- WhatsApp notifications (preferred, optional) ---
# Uses Meta WhatsApp Cloud API.
# WHATSAPP_TOKEN=EAAG...
# WHATSAPP_PHONE_NUMBER_ID=1234567890

# --- Telegram notifications (fallback, optional) ---
# TELEGRAM_BOT_TOKEN=123456:ABC...
# TELEGRAM_DEFAULT_CHAT_ID=-5178952799   # optional: send one message to a group/chat

# --- Email notifications (fallback, optional) ---
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL="Wakeel Shifts <noreply@yourdomain.com>"

# --- Optional: separate service accounts (two JSON files) ---
# If unset, Shifts uses the same credentials as main (email+key above, or main JSON below).
# GOOGLE_SHEETS_007SUP_SPREADSHEET_ID=   # alias for main sheet id (overrides default when used with main-only setups)
# GOOGLE_SHEETS_007SUP_CREDENTIALS_PATH=./credentials/service-account-007sup.json
# GOOGLE_SHEETS_007SUP_CREDENTIALS_JSON=   # full JSON one line (Vercel); alternative to PATH
# GOOGLE_SHEETS_SHIFTS_CREDENTIALS_PATH=./credentials/service-account-shifts.json
# GOOGLE_SHEETS_SHIFTS_CREDENTIALS_JSON=

