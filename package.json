{
  "name": "wakeel-team-management-system",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H 127.0.0.1 -p 3000",
    "dev:clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\" && next dev -H 127.0.0.1 -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "ensure-equipment-sheets": "npx --yes tsx scripts/ensure-equipment-sheets.ts",
    "ensure-recruitment-sheets": "npx --yes tsx scripts/ensure-recruitment-sheets.ts",
    "seed:recruitment": "npx --yes tsx scripts/seed-recruitment-data.ts",
    "test:talabat": "npx --yes tsx --test lib/strategicOps/talabatOpsMetrics.test.ts",
    "test:roadmap": "npx --yes tsx --test lib/strategicOps/roadmapCalculation.test.ts",
    "test:trust": "npx --yes tsx --test lib/strategicOps/trust/trustScoreEngine.test.ts lib/strategicOps/audit/kpiLineage.test.ts lib/strategicOps/systemHealth/healthMonitor.test.ts lib/strategicOps/trust/srs006Phase2.test.ts",
    "test:digital-twin": "npx --yes tsx --test lib/strategicOps/digitalTwin/scenarioEngine.test.ts lib/strategicOps/digitalTwin/srs007Phase2.test.ts",
    "test:ops-validation": "npx --yes tsx --test lib/strategicOps/opsValidation/opsValidation.test.ts",
    "test:enterprise-cert": "npx --yes tsx --test lib/strategicOps/enterpriseCert/enterpriseCert.test.ts",
    "cert:enterprise-gate": "npx --yes tsx scripts/enterprise-cert-gate.ts",
    "migrate:simulation": "npx --yes tsx scripts/migrate-simulation-scenarios.ts",
    "migrate:ticketing": "npx --yes tsx scripts/migrate-ticketing.ts",
    "export:sheets-backup": "npx --yes tsx scripts/export-sheets-backup.ts",
    "audit:password-hashes": "npx --yes tsx scripts/audit-password-hashes.ts",
    "migrate:passwords": "npx --yes tsx scripts/migrate-passwords-bcrypt.ts",
    "verify:neon-url": "npx --yes tsx scripts/verify-neon-url.ts",
    "activate:ticketing-neon": "npx --yes tsx scripts/activate-ticketing-neon.ts",
    "sync:ticketing-env": "npx --yes tsx scripts/sync-ticketing-env-local.ts && npx --yes tsx scripts/sync-ticketing-env-vercel.ts",
    "audit:redis": "npx --yes tsx scripts/audit-redis-production.ts",
    "verify:redis": "npx --yes tsx scripts/verify-redis-production.ts",
    "verify:sentry": "npx --yes tsx scripts/verify-sentry-production.ts",
    "migrate:mirror": "npx --yes tsx scripts/migrate-mirror.ts",
    "sync:mirror": "npx --yes tsx scripts/sync-sheets-mirror.ts",
    "verify:mirror": "npx --yes tsx scripts/verify-mirror.ts",
    "validate:mirror": "npx --yes tsx scripts/validate-mirror-data.ts",
    "benchmark:mirror": "npx --yes tsx scripts/benchmark-mirror-performance.ts",
    "benchmark:mirror-final": "npx --yes tsx scripts/benchmark-mirror-final.ts",
    "audit:mirror-queries": "npx --yes tsx scripts/audit-neon-mirror-queries.ts",
    "mirror:apply-indexes": "npx --yes tsx scripts/apply-mirror-indexes.ts",
    "preview:uat": "npx --yes tsx scripts/preview-uat-monitor.ts",
    "backup:sheets": "npx --yes tsx scripts/backup-sheets.ts",
    "backup:neon": "npx --yes tsx scripts/backup-neon.ts",
    "backup:r2": "npx --yes tsx scripts/backup-r2.ts",
    "backup:daily": "npx --yes tsx scripts/run-daily-backups.ts",
    "load-test:dashboard": "npx --yes tsx scripts/load-test-dashboard.ts",
    "load-test:strategic-ops": "npx --yes tsx scripts/load-test-strategic-ops.ts",
    "load-test:ticketing": "npx --yes tsx scripts/load-test-ticketing.ts",
    "env:pull": "npx --yes vercel@latest env pull .env.vercel.prod --environment=production --yes && node scripts/merge-env-local.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1073.0",
    "@resvg/resvg-js": "^2.6.2",
    "@sentry/nextjs": "^10.60.0",
    "@tanstack/react-query": "^5.17.0",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^2.0.0",
    "bcryptjs": "^2.4.3",
    "date-fns": "^2.30.0",
    "googleapis": "^126.0.1",
    "js-cookie": "^3.0.5",
    "jsonwebtoken": "^9.0.2",
    "next": "^14.0.4",
    "papaparse": "^5.5.3",
    "postgres": "^3.4.9",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.10.3",
    "satori": "^0.26.0",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/js-cookie": "^3.0.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.6",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^18.2.46",
    "@types/react-dom": "^18.2.18",
    "autoprefixer": "^10.4.16",
    "dotenv": "^17.2.3",
    "eslint": "8.57.0",
    "eslint-config-next": "14.0.4",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.3"
  },
  "overrides": {
    "eslint-config-next": "14.0.4"
  }
}
